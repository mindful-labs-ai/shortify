# Shortify dev 환경 변수 예시
# 실제 값은 macOS Keychain에 저장되며, dev 모드에서만 이 파일을 사용한다.
# 사용법: cp .env.example .env && 값 채우기

# Google Gemini API (모든 외부 AI 호출에 사용)
GEMINI_API_KEY=

# Sidecar dev 서버
SHORTIFY_HOST=127.0.0.1
SHORTIFY_PORT=51234
SHORTIFY_TOKEN=dev-only-token-do-not-use-in-production

# 데이터 저장 경로 (dev 모드에서만 오버라이드 가능)
# 기본: ~/Library/Application Support/Shortify
# SHORTIFY_DATA_DIR=

# 번들 ffmpeg 경로 (dev에서는 시스템 ffmpeg 사용 가능)
# SHORTIFY_FFMPEG=/usr/local/bin/ffmpeg

# Veo I2V 클립 길이 (초). Veo 3.x 류는 4~8 inclusive. 기본 6.
# SHORTIFY_VIDEO_DURATION_SEC=6

# 테스트 모드 — Imagen / Veo 호출량을 줄여 dev 사이클을 빠르게.
# SHORTIFY_TEST_MODE=1 이면 SHORTIFY_TEST_SCENE_COUNT (기본 2) 만큼만 씬 생성.
# prod 기본은 14 씬.
# SHORTIFY_TEST_MODE=1
# SHORTIFY_TEST_SCENE_COUNT=2
