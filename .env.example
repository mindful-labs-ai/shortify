# Shortify dev 환경 변수 예시
# 실제 값은 macOS Keychain에 저장되며, dev 모드에서만 이 파일을 사용한다.
# 사용법: cp .env.example .env && 값 채우기

# Google Gemini API (모든 외부 AI 호출에 사용)
GEMINI_API_KEY=

# Sidecar dev 서버
SHORTIFY_HOST=127.0.0.1
SHORTIFY_PORT=51234
SHORTIFY_TOKEN=dev-only-token-do-not-use-in-production

# 데이터 저장 경로 (dev 모드에서만 오버라이드 가능)
# 기본: ~/Library/Application Support/Shortify
# SHORTIFY_DATA_DIR=

# 번들 ffmpeg 경로 (dev에서는 시스템 ffmpeg 사용 가능)
# SHORTIFY_FFMPEG=/usr/local/bin/ffmpeg

# Veo I2V 클립 길이 (초). Veo 3.x 류는 4~8 inclusive. 기본 6.
# SHORTIFY_VIDEO_DURATION_SEC=6

# Veo I2V HTTP read timeout (초). 기본 300 (5분).
# 'The read operation timed out' 발생 시 늘려서 재시도.
# SHORTIFY_VEO_TIMEOUT_SEC=300

# Gemini TTS 보이스 (prebuilt 이름). 미지정시 'Kore'.
# 다른 옵션: Aoede, Charon, Fenrir, Puck, ... (SDK / 모델 문서 참고)
# SHORTIFY_TTS_VOICE=Kore

# Gemini 모델 ID. 키 권한/모델 가용성에 따라 변경 가능.
# 활성 ID 는 GET /admin/gemini/models 로 확인.
# SHORTIFY_MODEL_TEXT=models/gemini-3.1-flash-lite-preview
# SHORTIFY_MODEL_IMAGE=models/gemini-3.1-flash-image-preview
# SHORTIFY_MODEL_VIDEO=models/veo-3.1-fast-generate-preview
# SHORTIFY_MODEL_TTS=models/gemini-3.1-flash-tts-preview
# SHORTIFY_MODEL_AUDIO=models/gemini-3.1-flash-lite-preview

# image_concepts 의 ref_*.png 를 어디서 읽을지.
# 미설정시 → 로컬 absolute path (assets/image_concepts/<slug>/ref_*.png).
# 외부 호스트 사용 시 base URL 만 지정. 자동으로
#   <base>/image_concepts/<slug>/<file>.png
# 로 구성하고 사이드카가 1회 다운로드 후 ref_cache/ 에 저장.
# 예시: S3 public 버킷
# SHORTIFY_ASSETS_BASE_URL=https://hackathon-shortify.s3.ap-northeast-2.amazonaws.com

# 테스트 모드 — Imagen / Veo 호출량을 줄여 dev 사이클을 빠르게.
# SHORTIFY_TEST_MODE=1 이면 SHORTIFY_TEST_SCENE_COUNT (기본 2) 만큼만 씬 생성.
# prod 기본은 14 씬.
# SHORTIFY_TEST_MODE=1
# SHORTIFY_TEST_SCENE_COUNT=2
