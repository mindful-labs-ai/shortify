{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shortify",
  "version": "0.0.0",
  "identifier": "ai.mindful-labs.shortify",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shortify",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "externalBin": [],
    "resources": []
  }
}
